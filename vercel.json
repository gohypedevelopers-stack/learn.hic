{
    "framework": "nextjs",
    "buildCommand": "next build",
    "installCommand": "npm install",
    "outputDirectory": ".next",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOWALL"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://learn-hic.vercel.app https://app.clientmagnetplatform.com https://*.clientmagnetplatform.com"
                }
            ]
        }
    ]
}